# Server
PORT=5000
NODE_ENV=development

# Required auth secret (server refuses to start if missing)
JWT_SECRET=replace_with_a_long_random_secret

# Allowlist frontend origins (comma-separated)
# Example: https://your-frontend.vercel.app,http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limits
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=12

# Gemini
GEMINI_API_KEY=replace_with_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
FRONTEND_BASE_URL=http://localhost:3000

# Firebase Admin (choose one option)
# Option A: path to service account json (local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option B: full JSON string in one env variable (cloud deploy)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Optional account lifecycle / session hardening
EMAIL_VERIFICATION_REQUIRED=false
SESSION_COOKIE_NAME=cooture_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_MAX_AGE_MS=604800000
SESSION_TOKEN_TTL=7d
